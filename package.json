{
  "name": "polis",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "POLIS (Poster Overlay Layer Integration Service). Self-hosted poster overlays for Aurora and compatible players.",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --bun next dev -p 3050",
    "dev:clean": "rm -rf .next && bun --bun next dev -p 3050",
    "build": "bun --bun next build",
    "build:clean": "rm -rf .next && bun --bun next build",
    "sync:fonts": "sh scripts/sync-overlay-fonts.sh",
    "fetch:fonts": "sh scripts/fetch-overlay-fonts.sh",
    "start": "bun --bun next start -p 3050"
  },
  "dependencies": {
    "lucide-react": "^0.553.0",
    "next": "^15.5.18",
    "opentype.js": "^2.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@fontsource/dejavu-sans": "^5.2.5",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
